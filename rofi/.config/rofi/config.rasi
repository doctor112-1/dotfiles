@import "catppuccin-mocha"
@theme "catppuccin-default"

configuration {
  display-drun: "apps: ";
  display-window: "search: ";
  font: "Pragmasevka Nerd Font 17";
}

window {
  location: center;
}

inputbar {
  children: [ prompt, entry ];
}

prompt {
  font: "Pragmasevka Nerd Font 17";
}

entry {
  font: "Pragmasevka Nerd Font 17";
}

element {
  padding: 2px;
}
